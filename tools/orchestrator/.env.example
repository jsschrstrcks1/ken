# API keys — copy this file to .env and fill in your keys
# .env is gitignored and will never be committed

# OpenAI (GPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Google (Gemini) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-free-tier-key-here
GOOGLE_API_KEY_PAID=your-paid-tier-key-here

# xAI (Grok) — https://console.x.ai
XAI_API_KEY=your-key-here

# Perplexity — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your-key-here

# You.com — https://api.you.com (used by Stage 2 investigate)
YDC_API_KEY=your-key-here

# Google Cloud / Vertex AI — used by the Vertex adapter for higher-quota Gemini access
# https://console.cloud.google.com/apis/credentials
VERTEX_API_KEY=your-key-here
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
