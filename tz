#!/bin/bash

# Timezone helper for travelers
# Usage: tz                              show current timezone
#        tz <city or timezone>           set timezone
#        tz here                         detect from network and set
#        tz explain                      show timezone state and source
#        tz list <keyword>              search cities/timezones
#        tz schedule                    show scheduled timezone changes
#        tz schedule add <date> <city>  add scheduled change
#        tz schedule clear              remove all scheduled entries
#        tz schedule check [--query]    apply today's timezone (--query = no apply)
#        tz cruise start <date>         start building a cruise itinerary
#        tz cruise <city>               add next port (auto-SEA inference)
#        tz cruise +<city>              same-day port (no date advance)
#        tz cruise sea                  explicit sea day
#        tz cruise load <file>          load itinerary from file
#        tz cruise end                  finish cruise itinerary
#        tz cruise show                 show cruise being built
#        tz undo                        remove last schedule entry

CITIES_FILE="/usr/local/share/tz-cities"
SCHEDULE_FILE="/etc/tz-schedule"
CRUISE_STATE="/var/lib/tz/cruise-state"

# --- Helper Functions ---

lookup_city() {
    local query
    query=$(echo "$*" | tr '[:upper:]' '[:lower:]')

    if [ -f "$CITIES_FILE" ]; then
        grep -i "^${query}|" "$CITIES_FILE" 2>/dev/null | head -1 | cut -d'|' -f2
    fi
}

resolve_timezone() {
    # Try as a timezone name first (e.g. America/Denver)
    if [ -f "/usr/share/zoneinfo/$1" ]; then
        echo "$1"
        return 0
    fi

    # Try as a city name
    local tz
    tz=$(lookup_city "$@")
    if [ -n "$tz" ]; then
        echo "$tz"
        return 0
    fi

    return 1
}

apply_timezone() {
    local tz="$1"
    echo "$tz" > /etc/timezone
    ln -sf "/usr/share/zoneinfo/$tz" /etc/localtime
}

next_date() {
    # Given a date YYYY-MM-DD, return the next day
    date -d "$1 + 1 day" +%Y-%m-%d 2>/dev/null || \
    date -j -v+1d -f "%Y-%m-%d" "$1" +%Y-%m-%d 2>/dev/null
}

# --- Commands ---

cmd_show() {
    echo "Current timezone: $(cat /etc/timezone 2>/dev/null || echo 'unknown')"
    echo "Current time:     $(date)"

    # Show next scheduled change if any
    if [ -f "$SCHEDULE_FILE" ]; then
        local today next
        today=$(date +%Y-%m-%d)
        next=$(grep -v '^#' "$SCHEDULE_FILE" 2>/dev/null | grep -v '^$' | awk -v today="$today" '$1 > today { print; exit }')
        if [ -n "$next" ]; then
            echo ""
            echo "Next scheduled: $next"
        fi
    fi

    # Show if cruise is being built
    if [ -f "$CRUISE_STATE" ]; then
        echo ""
        echo "(Cruise itinerary in progress - use 'tz cruise <port>' to add ports)"
    fi
}

cmd_set() {
    local tz
    tz=$(resolve_timezone "$@")

    if [ -z "$tz" ]; then
        echo "Error: '$*' not recognized as a timezone or city."
        echo "Try: tz list $1"
        exit 1
    fi

    apply_timezone "$tz"
    echo "Timezone set to $tz"
    date
}

cmd_list() {
    local keyword
    keyword=$(echo "$*" | tr '[:upper:]' '[:lower:]')

    if [ -z "$keyword" ]; then
        echo "Usage: tz list <keyword>"
        echo "Examples: tz list caribbean, tz list europe, tz list miami"
        exit 1
    fi

    echo "Matching cities/regions for '$keyword':"
    echo ""

    if [ -f "$CITIES_FILE" ]; then
        grep -i "$keyword" "$CITIES_FILE" 2>/dev/null | grep -v '^#' | while IFS='|' read -r city timezone; do
            printf "  %-25s %s\n" "$city" "$timezone"
        done
    fi

    # Also search zoneinfo
    echo ""
    echo "Matching timezone names:"
    echo ""
    find /usr/share/zoneinfo -type f 2>/dev/null | sed 's|/usr/share/zoneinfo/||' | grep -i "$keyword" | grep '/' | sort | while read -r tz; do
        printf "  %s\n" "$tz"
    done
}

cmd_undo() {
    if [ ! -f "$SCHEDULE_FILE" ]; then
        echo "No schedule to undo."
        exit 1
    fi

    # Get the last non-comment, non-empty line
    local last_entry
    last_entry=$(grep -v '^#' "$SCHEDULE_FILE" | grep -v '^$' | tail -1)

    if [ -z "$last_entry" ]; then
        echo "No entries to undo."
        exit 1
    fi

    # Remove the last line that matches
    sed -i "\|^${last_entry}$|d" "$SCHEDULE_FILE"
    echo "Removed: $last_entry"
}

cmd_cruise() {
    local subcmd="${1:-}"
    shift 2>/dev/null || true

    case "$subcmd" in
        start)
            local start_date="$1"
            if [ -z "$start_date" ]; then
                echo "Usage: tz cruise start <YYYY-MM-DD>"
                echo "Example: tz cruise start 2026-02-24"
                exit 1
            fi

            if ! echo "$start_date" | grep -qP '^\d{4}-\d{2}-\d{2}$'; then
                echo "Error: date must be YYYY-MM-DD format"
                exit 1
            fi

            mkdir -p "$(dirname "$CRUISE_STATE")"
            echo "$start_date" > "$CRUISE_STATE"
            echo "Cruise itinerary started from $start_date"
            echo "Now add ports:  tz cruise <port name>"
            echo "Add sea days:   tz cruise sea"
            echo "When done:      tz cruise end"
            ;;
        end)
            if [ ! -f "$CRUISE_STATE" ]; then
                echo "No cruise in progress."
                exit 1
            fi
            rm -f "$CRUISE_STATE"
            echo "Cruise itinerary complete."
            echo ""
            cmd_schedule show
            ;;
        show)
            if [ ! -f "$CRUISE_STATE" ]; then
                echo "No cruise in progress."
                echo "Start one with: tz cruise start <YYYY-MM-DD>"
                exit 1
            fi
            local next_d
            next_d=$(cat "$CRUISE_STATE")
            echo "Cruise in progress. Next date: $next_d"
            echo ""
            cmd_schedule show
            ;;
        sea|SEA)
            if [ ! -f "$CRUISE_STATE" ]; then
                echo "No cruise in progress. Start one with: tz cruise start <date>"
                exit 1
            fi

            local current_date
            current_date=$(cat "$CRUISE_STATE")

            # For sea days, keep the previous timezone (or mark as SEA)
            # Get the last timezone from the schedule
            local last_tz
            last_tz=$(grep -v '^#' "$SCHEDULE_FILE" 2>/dev/null | grep -v '^$' | tail -1 | awk '{print $2}')

            if [ -z "$last_tz" ]; then
                last_tz=$(cat /etc/timezone 2>/dev/null || echo "UTC")
            fi

            # Create schedule file if needed
            if [ ! -f "$SCHEDULE_FILE" ]; then
                echo "# Timezone schedule - managed by tz command" > "$SCHEDULE_FILE"
                echo "# Format: YYYY-MM-DD timezone/name optional note" >> "$SCHEDULE_FILE"
            fi

            echo "$current_date $last_tz SEA" >> "$SCHEDULE_FILE"
            echo "Added: $current_date  $last_tz  (sea day)"

            # Advance date
            local next_d
            next_d=$(next_date "$current_date")
            echo "$next_d" > "$CRUISE_STATE"
            ;;
        load)
            local file="$1"
            if [ -z "$file" ] || [ ! -f "$file" ]; then
                echo "Usage: tz cruise load <file>"
                echo ""
                echo "File format (first line = start date, then one port per line):"
                echo "  2026-02-24"
                echo "  ensenada"
                echo "  sea"
                echo "  cabo san lucas"
                echo "  +kobe          (+ = same day as previous)"
                echo "  sea"
                echo "  los angeles"
                exit 1
            fi

            local line_num=0 start_date=""
            while IFS= read -r line || [ -n "$line" ]; do
                # Skip empty lines and comments
                line=$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
                [ -z "$line" ] && continue
                echo "$line" | grep -q '^#' && continue

                line_num=$((line_num + 1))

                if [ "$line_num" -eq 1 ]; then
                    # First line is the start date
                    start_date="$line"
                    cmd_cruise start "$start_date"
                else
                    # Remaining lines are ports or "sea"
                    cmd_cruise $line
                fi
            done < "$file"

            cmd_cruise end
            ;;
        "")
            echo "Usage: tz cruise <command>"
            echo ""
            echo "Commands:"
            echo "  tz cruise start <date>    Start building an itinerary"
            echo "  tz cruise <port>          Add next port (auto-increments date)"
            echo "  tz cruise +<port>         Add same-day port (no date advance)"
            echo "  tz cruise sea             Add a sea day"
            echo "  tz cruise load <file>     Load itinerary from file"
            echo "  tz cruise end             Finish itinerary"
            echo "  tz cruise show            Show itinerary in progress"
            echo ""
            echo "Example:"
            echo "  tz cruise start 2027-05-12"
            echo "  tz cruise tokyo"
            echo "  tz cruise shimizu"
            echo "  tz cruise nagoya"
            echo "  tz cruise osaka"
            echo "  tz cruise osaka"
            echo "  tz cruise +kobe"
            echo "  tz cruise sea"
            echo "  tz cruise sea"
            echo "  tz cruise los angeles"
            echo "  tz cruise end"
            ;;
        *)
            # This is a port name - add it to the cruise schedule
            if [ ! -f "$CRUISE_STATE" ]; then
                echo "No cruise in progress. Start one with: tz cruise start <date>"
                exit 1
            fi

            # Check for same-day prefix (+port means same calendar day)
            local same_day=false
            if echo "$subcmd" | grep -q '^+'; then
                same_day=true
                subcmd="${subcmd#+}"
            fi

            local current_date port_name resolved
            current_date=$(cat "$CRUISE_STATE")
            port_name="$subcmd $*"
            port_name=$(echo "$port_name" | sed 's/ *$//')

            resolved=$(resolve_timezone "$port_name")
            if [ -z "$resolved" ]; then
                # Try just the subcmd without extra args
                resolved=$(resolve_timezone "$subcmd")
                if [ -z "$resolved" ]; then
                    echo "Error: could not resolve timezone for '$port_name'"
                    echo "Try: tz list $subcmd"
                    exit 1
                fi
            fi

            # Create schedule file if needed
            if [ ! -f "$SCHEDULE_FILE" ]; then
                echo "# Timezone schedule - managed by tz command" > "$SCHEDULE_FILE"
                echo "# Format: YYYY-MM-DD timezone/name optional note" >> "$SCHEDULE_FILE"
            fi

            if [ "$same_day" = true ]; then
                # Same-day port: use previous date, no auto-SEA, no date advance
                local prev_date
                prev_date=$(grep -v '^#' "$SCHEDULE_FILE" 2>/dev/null | grep -v '^$' | tail -1 | awk '{print $1}')
                if [ -n "$prev_date" ]; then
                    current_date="$prev_date"
                fi
                echo "$current_date $resolved $port_name" >> "$SCHEDULE_FILE"
                echo "Added: $current_date  $resolved  ($port_name) (same day)"
            else
                # Auto-SEA inference: if timezone changes from previous port,
                # insert a sea day (ships change clocks at ~2am during sea days)
                local last_tz last_note
                last_tz=$(grep -v '^#' "$SCHEDULE_FILE" 2>/dev/null | grep -v '^$' | tail -1 | awk '{print $2}')
                last_note=$(grep -v '^#' "$SCHEDULE_FILE" 2>/dev/null | grep -v '^$' | tail -1 | awk '{$1=""; $2=""; print}' | sed 's/^ *//')
                if [ -n "$last_tz" ] && [ "$resolved" != "$last_tz" ] && [ "$last_note" != "SEA" ]; then
                    echo "$current_date $last_tz SEA" >> "$SCHEDULE_FILE"
                    echo "Added: $current_date  $last_tz  (sea day - auto)"
                    current_date=$(next_date "$current_date")
                fi

                echo "$current_date $resolved $port_name" >> "$SCHEDULE_FILE"
                echo "Added: $current_date  $resolved  ($port_name)"

                # Advance date
                local next_d
                next_d=$(next_date "$current_date")
                echo "$next_d" > "$CRUISE_STATE"
            fi
            ;;
    esac
}

cmd_schedule() {
    local subcmd="${1:-}"
    shift 2>/dev/null || true

    case "$subcmd" in
        ""|show)
            if [ ! -f "$SCHEDULE_FILE" ] || [ ! -s "$SCHEDULE_FILE" ]; then
                echo "No timezone schedule set."
                echo "Use: tz schedule add <date> <city> [note]"
                echo "Or:  tz cruise start <date>"
                exit 0
            fi
            echo "Timezone schedule:"
            echo ""
            local today
            today=$(date +%Y-%m-%d)
            printf "  %-12s %-28s %s\n" "DATE" "TIMEZONE" "NOTE"
            printf "  %-12s %-28s %s\n" "----" "--------" "----"
            grep -v '^#' "$SCHEDULE_FILE" | grep -v '^$' | while read -r date tz note; do
                local marker=""
                if [ "$date" = "$today" ]; then
                    marker=" <-- today"
                fi
                printf "  %-12s %-28s %s%s\n" "$date" "$tz" "$note" "$marker"
            done
            ;;
        add)
            local date="$1"
            shift
            local resolved="" note=""
            local words=("$@")
            local i

            for i in $(seq ${#words[@]} -1 1); do
                local try="${words[*]:0:$i}"
                resolved=$(resolve_timezone "$try")
                if [ -n "$resolved" ]; then
                    note="${words[*]:$i}"
                    break
                fi
            done

            if [ -z "$resolved" ]; then
                echo "Error: could not resolve timezone from '$*'"
                echo "Try: tz list <keyword> to find the right name"
                exit 1
            fi

            if ! echo "$date" | grep -qP '^\d{4}-\d{2}-\d{2}$'; then
                echo "Error: date must be YYYY-MM-DD format"
                exit 1
            fi

            if [ ! -f "$SCHEDULE_FILE" ]; then
                echo "# Timezone schedule - managed by tz command" > "$SCHEDULE_FILE"
                echo "# Format: YYYY-MM-DD timezone/name optional note" >> "$SCHEDULE_FILE"
            fi

            echo "$date $resolved $note" >> "$SCHEDULE_FILE"

            {
                grep '^#' "$SCHEDULE_FILE"
                grep -v '^#' "$SCHEDULE_FILE" | grep -v '^$' | sort
            } > "${SCHEDULE_FILE}.tmp" && mv "${SCHEDULE_FILE}.tmp" "$SCHEDULE_FILE"

            echo "Added: $date  $resolved  $note"
            ;;
        clear)
            rm -f "$SCHEDULE_FILE"
            echo "Schedule cleared."
            ;;
        check)
            local query_only=false
            if [ "${1:-}" = "--query" ]; then
                query_only=true
            fi
            if [ ! -f "$SCHEDULE_FILE" ]; then
                return 1 2>/dev/null || exit 1
            fi
            local today tz
            today=$(date +%Y-%m-%d)
            tz=$(grep -v '^#' "$SCHEDULE_FILE" 2>/dev/null | grep "^$today " | tail -1 | awk '{print $2}')
            if [ -n "$tz" ] && [ -f "/usr/share/zoneinfo/$tz" ]; then
                if [ "$query_only" = false ]; then
                    apply_timezone "$tz"
                fi
                echo "$tz"
                return 0 2>/dev/null || exit 0
            fi
            return 1 2>/dev/null || exit 1
            ;;
        *)
            echo "Usage: tz schedule [show|add|clear|check]"
            exit 1
            ;;
    esac
}

cmd_here() {
    local tz=""

    echo "Detecting timezone from network..."

    # Try primary GeoIP
    tz=$(curl -s --max-time 5 "https://worldtimeapi.org/api/ip" 2>/dev/null | grep -oP '"timezone"\s*:\s*"\K[^"]+')

    # Try fallback
    if [ -z "$tz" ]; then
        tz=$(curl -s --max-time 5 "https://ipapi.co/timezone" 2>/dev/null)
    fi

    if [ -z "$tz" ] || [ ! -f "/usr/share/zoneinfo/$tz" ]; then
        echo "Error: could not detect timezone from network."
        exit 1
    fi

    local current
    current=$(cat /etc/timezone 2>/dev/null || echo "unknown")
    apply_timezone "$tz"
    if [ "$tz" = "$current" ]; then
        echo "Detected: $tz (no change)"
    else
        echo "Detected: $tz (was $current)"
    fi
    date
}

cmd_explain() {
    local tz offset
    tz=$(cat /etc/timezone 2>/dev/null || echo "unknown")
    offset=$(date +%z)

    echo "Timezone:   $tz"
    echo "Local time: $(date '+%Y-%m-%d %H:%M:%S')"
    echo "UTC offset: ${offset:0:3}:${offset:3:2}"

    # Schedule status
    if [ -f "$SCHEDULE_FILE" ] && [ -s "$SCHEDULE_FILE" ]; then
        local today today_entry next_entry
        today=$(date +%Y-%m-%d)
        today_entry=$(grep -v '^#' "$SCHEDULE_FILE" 2>/dev/null | grep -v '^$' | grep "^$today " | tail -1)
        next_entry=$(grep -v '^#' "$SCHEDULE_FILE" 2>/dev/null | grep -v '^$' | awk -v today="$today" '$1 > today { print; exit }')

        echo ""
        if [ -n "$today_entry" ]; then
            local entry_tz entry_note
            entry_tz=$(echo "$today_entry" | awk '{print $2}')
            entry_note=$(echo "$today_entry" | awk '{$1=""; $2=""; print}' | sed 's/^ *//')
            echo "Schedule:   active"
            echo "Today:      $today — $entry_note ($entry_tz)"
        else
            echo "Schedule:   exists (no entry for today)"
        fi

        if [ -n "$next_entry" ]; then
            local next_date next_tz next_note
            next_date=$(echo "$next_entry" | awk '{print $1}')
            next_tz=$(echo "$next_entry" | awk '{print $2}')
            next_note=$(echo "$next_entry" | awk '{$1=""; $2=""; print}' | sed 's/^ *//')
            echo "Next:       $next_date — $next_note ($next_tz)"
        fi
    else
        echo ""
        echo "Schedule:   none"
    fi

    # Cruise state
    if [ -f "$CRUISE_STATE" ]; then
        echo ""
        echo "Cruise:     in progress (next date: $(cat "$CRUISE_STATE"))"
    fi
}

# --- Main ---

case "${1:-}" in
    "")
        cmd_show
        ;;
    here)
        cmd_here
        ;;
    explain)
        cmd_explain
        ;;
    list)
        shift
        cmd_list "$@"
        ;;
    schedule)
        shift
        cmd_schedule "$@"
        ;;
    cruise)
        shift
        cmd_cruise "$@"
        ;;
    undo)
        cmd_undo
        ;;
    help|-h|--help)
        echo "tz - timezone helper for travelers"
        echo ""
        echo "Usage:"
        echo "  tz                              Show current timezone"
        echo "  tz <city or timezone>           Set timezone"
        echo "  tz here                         Detect from network and set"
        echo "  tz explain                      Show timezone state and source"
        echo "  tz list <keyword>               Search cities/timezones"
        echo "  tz undo                         Remove last schedule entry"
        echo ""
        echo "Schedule:"
        echo "  tz schedule                     Show scheduled changes"
        echo "  tz schedule add <date> <city>   Add scheduled change"
        echo "  tz schedule clear               Clear all scheduled changes"
        echo ""
        echo "Cruise mode:"
        echo "  tz cruise start <date>          Start cruise itinerary"
        echo "  tz cruise <port>                Add next port day"
        echo "  tz cruise +<port>               Same-day port (no date advance)"
        echo "  tz cruise sea                   Add a sea day"
        echo "  tz cruise load <file>           Load itinerary from file"
        echo "  tz cruise end                   Finish itinerary"
        echo "  tz cruise show                  Show itinerary in progress"
        echo ""
        echo "Examples:"
        echo "  tz tampa"
        echo "  tz here"
        echo "  tz list caribbean"
        echo "  tz cruise start 2027-05-12"
        echo "  tz cruise tokyo"
        echo "  tz cruise osaka"
        echo "  tz cruise +kobe                 # same day as osaka"
        echo "  tz cruise sea"
        echo "  tz cruise los angeles"
        echo "  tz cruise end"
        echo "  tz cruise load ~/cruises/japan-2027.txt"
        ;;
    *)
        cmd_set "$@"
        ;;
esac
