  "skills": {
    "orchestrate": {
      "enabled": true,
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Full multi-LLM pipeline orchestration. This is the hub \u2014 no default mode. Specify sermon, sheep, cruising, recipe, or family-history explicitly.",
      "promptTriggers": {
        "keywords": [
          "orchestrate",
          "pipeline",
          "multi-model",
          "multi-llm",
          "full pipeline",
          "run pipeline",
          "family-history"
