        "intentPatterns": [
          "(orchestrate|run pipeline|full pipeline).*?(sermon|sheep|cruising|recipe|family-history)",
          "(coordinate|consult).*?(multiple|all).*?model"
        ]
      },
      "autoLoad": {
        "mainFile": ".claude/skills/orchestrate/SKILL.md",
        "maxLines": 200,
        "loadOnFirstFileEdit": false
      },
      "activationMessage": "Orchestrator hub active. Specify mode: sermon, sheep, cruising, recipe, or family-history."
    },
