#!/bin/sh
# Triggered by if-up.d when a network interface comes up.
# Checks if the network has changed and runs timezone detection if so.

CACHE_DIR="/var/cache/tz"
STATE_FILE="$CACHE_DIR/network-state"
COOLDOWN_FILE="$CACHE_DIR/last-network-check"
COOLDOWN=300  # 5 minutes

# Cooldown: don't run more than once per 5 minutes
NOW=$(date +%s)
LAST=$(cat "$COOLDOWN_FILE" 2>/dev/null || echo 0)
if [ $((NOW - LAST)) -lt "$COOLDOWN" ]; then
    exit 0
fi

# Build network fingerprint
SSID=$(iwgetid -r 2>/dev/null || echo "none")
GW=$(ip route 2>/dev/null | awk '/default/ {print $3; exit}')
FINGERPRINT="$SSID|$GW"

# Compare with previous fingerprint
OLD=$(cat "$STATE_FILE" 2>/dev/null || echo "")
if [ "$FINGERPRINT" = "$OLD" ]; then
    exit 0
fi

# Network changed — save state and run sync
mkdir -p "$CACHE_DIR"
echo "$FINGERPRINT" > "$STATE_FILE"
echo "$NOW" > "$COOLDOWN_FILE"

logger "tz-network-check: network changed ($OLD -> $FINGERPRINT), running timezone detection"
/usr/local/bin/sync-clock.sh
